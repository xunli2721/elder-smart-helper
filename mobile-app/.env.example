# API Configuration
API_BASE_URL=http://localhost:3000/api
WEBSOCKET_URL=ws://localhost:3000

# App Configuration
APP_NAME=ElderSmartHelper
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Feature Flags
FEATURE_VOICE_ASSISTANT=true
FEATURE_REMOTE_ASSISTANCE=true
FEATURE_SECURITY_MONITORING=true
FEATURE_OFFLINE_MODE=true

# UI Configuration
DEFAULT_FONT_SIZE=18
DEFAULT_CONTRAST_RATIO=4.5
DEFAULT_VOICE_SPEED=1  # 1=slow, 2=normal, 3=fast
ENABLE_HAPTIC_FEEDBACK=true
ENABLE_SOUND_FEEDBACK=true

# Security Configuration
ENCRYPTION_KEY=your_encryption_key_here_change_in_production
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5

# Analytics Configuration
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=UA-XXXXXXXX-X
CRASH_REPORTING_ENABLED=false

# Localization
DEFAULT_LANGUAGE=zh-CN
SUPPORTED_LANGUAGES=zh-CN,en-US

# Cache Configuration
CACHE_MAX_SIZE_MB=100
CACHE_EXPIRY_DAYS=7

# Image Configuration
MAX_IMAGE_SIZE_MB=5
IMAGE_QUALITY=80

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_BITRATE=128000
AUDIO_CHANNELS=1

# Video Configuration
VIDEO_QUALITY=720p
VIDEO_MAX_DURATION_SECONDS=300

# Testing Configuration
MOCK_API_RESPONSES=false
SKIP_SPLASH_SCREEN=false

# Development Flags
DEBUG_MODE=true
LOG_NETWORK_REQUESTS=true
SHOW_DEV_MENU=true