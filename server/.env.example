# Server Configuration
PORT=3000
NODE_ENV=development
APP_NAME=ElderSmartHelper
APP_VERSION=1.0.0

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=elder_smart_helper
DB_USER=root
DB_PASSWORD=password
DB_CONNECTION_LIMIT=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# Security Configuration
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# AI Services Configuration
AI_SPEECH_RECOGNITION_ENABLED=false
AI_SPEECH_SYNTHESIS_ENABLED=false
AI_FRAUD_DETECTION_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key-here

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@eldersmarthelper.com

# SMS Configuration (for verification)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notification Configuration
FCM_SERVER_KEY=your_fcm_server_key
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id
APNS_KEY_FILE_PATH=./config/apns-key.p8

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_MAX_FILES=10

# Monitoring Configuration
SENTRY_DSN=your_sentry_dsn_here
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key

# Feature Flags
FEATURE_REMOTE_ASSISTANCE_ENABLED=true
FEATURE_VOICE_ASSISTANT_ENABLED=true
FEATURE_SECURITY_MONITORING_ENABLED=true
FEATURE_TUTORIAL_SYSTEM_ENABLED=true