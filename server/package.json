{
  "name": "elder-smart-helper-server",
  "version": "2.0.0",
  "description": "ElderSmartHelper Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "set JWT_SECRET=test_jwt_secret_key&& jest --forceExit --detectOpenHandles",
    "test:coverage": "set JWT_SECRET=test_jwt_secret_key&& jest --coverage --forceExit --detectOpenHandles",
    "db:migrate": "node ../database/run_migration.js migrate",
    "db:seed": "node ../database/run_migration.js seed",
    "db:status": "node ../database/run_migration.js status",
    "db:reset": "node ../database/run_migration.js reset"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.3.3",
    "socket.io": "^4.6.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
