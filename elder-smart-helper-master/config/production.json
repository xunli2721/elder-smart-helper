{
  "environment": "production",
  "debug": false,
  "server": {
    "port": 3000,
    "host": "0.0.0.0",
    "cors": {
      "origin": ["https://app.eldersmarthelper.com", "https://admin.eldersmarthelper.com"],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 100
    },
    "trustProxy": true,
    "compression": true
  },
  "database": {
    "mysql": {
      "host": "production-db.cluster-custom-identifier.region.rds.amazonaws.com",
      "port": 3306,
      "database": "elder_smart_helper_prod",
      "username": "prod_user",
      "password": "${DB_PASSWORD}",
      "dialect": "mysql",
      "logging": false,
      "pool": {
        "max": 50,
        "min": 5,
        "acquire": 30000,
        "idle": 10000
      },
      "ssl": true,
      "dialectOptions": {
        "ssl": {
          "require": true,
          "rejectUnauthorized": false
        }
      }
    },
    "redis": {
      "host": "production-redis-cluster.region.cache.amazonaws.com",
      "port": 6379,
      "password": "${REDIS_PASSWORD}",
      "db": 0,
      "tls": {}
    }
  },
  "security": {
    "jwt": {
      "secret": "${JWT_SECRET}",
      "expiresIn": "7d",
      "refreshSecret": "${JWT_REFRESH_SECRET}",
      "refreshExpiresIn": "30d"
    },
    "bcrypt": {
      "saltRounds": 12
    },
    "encryption": {
      "algorithm": "aes-256-gcm",
      "key": "${ENCRYPTION_KEY}"
    },
    "csp": {
      "enabled": true,
      "directives": {
        "defaultSrc": ["'self'"],
        "scriptSrc": ["'self'", "'unsafe-inline'"],
        "styleSrc": ["'self'", "'unsafe-inline'"],
        "imgSrc": ["'self'", "data:", "https:"],
        "connectSrc": ["'self'", "https://api.eldersmarthelper.com"],
        "fontSrc": ["'self'"],
        "objectSrc": ["'none'"],
        "mediaSrc": ["'self'"],
        "frameSrc": ["'none'"]
      }
    }
  },
  "aiServices": {
    "speechRecognition": {
      "enabled": true,
      "provider": "azure",
      "language": "zh-CN",
      "azure": {
        "key": "${AZURE_SPEECH_KEY}",
        "region": "eastasia"
      }
    },
    "speechSynthesis": {
      "enabled": true,
      "provider": "azure",
      "voice": "zh-CN-XiaoxiaoNeural",
      "azure": {
        "key": "${AZURE_SPEECH_KEY}",
        "region": "eastasia"
      }
    },
    "fraudDetection": {
      "enabled": true,
      "provider": "custom",
      "modelPath": "./ai-models/fraud-detection-v1.2.0",
      "apiKey": "${FRAUD_DETECTION_API_KEY}"
    }
  },
  "storage": {
    "local": {
      "uploadDir": "/data/uploads",
      "maxFileSize": 52428800,
      "allowedTypes": ["image/jpeg", "image/png", "image/gif", "video/mp4", "application/pdf"]
    },
    "cloud": {
      "enabled": true,
      "provider": "aliyun",
      "bucket": "elder-smart-helper-prod",
      "region": "oss-cn-hangzhou",
      "accessKeyId": "${OSS_ACCESS_KEY_ID}",
      "accessKeySecret": "${OSS_ACCESS_KEY_SECRET}",
      "cdnDomain": "cdn.eldersmarthelper.com"
    }
  },
  "notifications": {
    "email": {
      "enabled": true,
      "smtp": {
        "host": "${SMTP_HOST}",
        "port": 587,
        "secure": true,
        "auth": {
          "user": "${SMTP_USER}",
          "pass": "${SMTP_PASSWORD}"
        }
      },
      "from": "noreply@eldersmarthelper.com",
      "templates": {
        "welcome": "welcome-email.html",
        "passwordReset": "password-reset.html",
        "securityAlert": "security-alert.html"
      }
    },
    "sms": {
      "enabled": true,
      "provider": "twilio",
      "accountSid": "${TWILIO_ACCOUNT_SID}",
      "authToken": "${TWILIO_AUTH_TOKEN}",
      "fromNumber": "${TWILIO_PHONE_NUMBER}"
    },
    "push": {
      "enabled": true,
      "fcm": {
        "serverKey": "${FCM_SERVER_KEY}"
      },
      "apns": {
        "keyId": "${APNS_KEY_ID}",
        "teamId": "${APNS_TEAM_ID}",
        "keyFile": "./config/apns-key-prod.p8",
        "bundleId": "com.eldersmarthelper.app",
        "production": true
      }
    }
  },
  "monitoring": {
    "enabled": true,
    "sentry": {
      "dsn": "${SENTRY_DSN}",
      "environment": "production",
      "tracesSampleRate": 0.1
    },
    "newRelic": {
      "licenseKey": "${NEW_RELIC_LICENSE_KEY}",
      "appName": "ElderSmartHelper-Production"
    },
    "metrics": {
      "enabled": true,
      "port": 9090,
      "path": "/metrics"
    },
    "healthChecks": {
      "enabled": true,
      "path": "/health",
      "interval": 30000
    }
  },
  "features": {
    "remoteAssistance": {
      "enabled": true,
      "maxSessionsPerUser": 5,
      "sessionTimeout": 1800,
      "recording": true
    },
    "voiceAssistant": {
      "enabled": true,
      "wakeWord": "小助",
      "timeout": 10000,
      "offlineMode": true
    },
    "securityMonitoring": {
      "enabled": true,
      "alertThreshold": {
        "high": 5,
        "medium": 3,
        "low": 1
      },
      "autoBlock": true
    },
    "tutorialSystem": {
      "enabled": true,
      "autoRecommend": true,
      "completionReward": true,
      "personalization": true
    }
  },
  "logging": {
    "level": "info",
    "transports": ["file", "console"],
    "file": {
      "filename": "/var/log/elder-smart-helper/app.log",
      "maxsize": 104857600,
      "maxFiles": 10,
      "zippedArchive": true
    },
    "format": "json",
    "meta": {
      "service": "elder-smart-helper",
      "environment": "production"
    }
  },
  "cdn": {
    "enabled": true,
    "domain": "cdn.eldersmarthelper.com",
    "cacheControl": {
      "images": "public, max-age=31536000",
      "scripts": "public, max-age=86400",
      "styles": "public, max-age=86400"
    }
  },
  "scaling": {
    "cluster": {
      "enabled": true,
      "instances": 4
    },
    "loadBalancer": {
      "enabled": true,
      "healthCheck": {
        "path": "/health",
        "interval": 30,
        "timeout": 5,
        "healthyThreshold": 2,
        "unhealthyThreshold": 2
      }
    }
  }
}