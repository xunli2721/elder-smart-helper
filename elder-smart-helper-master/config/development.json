{
  "environment": "development",
  "debug": true,
  "server": {
    "port": 3000,
    "host": "localhost",
    "cors": {
      "origin": ["http://localhost:3001", "http://localhost:8080"],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 100
    }
  },
  "database": {
    "mysql": {
      "host": "localhost",
      "port": 3306,
      "database": "elder_smart_helper",
      "username": "root",
      "password": "password",
      "dialect": "mysql",
      "logging": true,
      "pool": {
        "max": 10,
        "min": 0,
        "acquire": 30000,
        "idle": 10000
      }
    },
    "redis": {
      "host": "localhost",
      "port": 6379,
      "password": "",
      "db": 0
    }
  },
  "security": {
    "jwt": {
      "secret": "development_jwt_secret_key_here",
      "expiresIn": "7d",
      "refreshSecret": "development_refresh_secret_key_here",
      "refreshExpiresIn": "30d"
    },
    "bcrypt": {
      "saltRounds": 10
    },
    "encryption": {
      "algorithm": "aes-256-gcm",
      "key": "development_encryption_key_32_bytes_long"
    }
  },
  "aiServices": {
    "speechRecognition": {
      "enabled": false,
      "provider": "local",
      "language": "zh-CN"
    },
    "speechSynthesis": {
      "enabled": false,
      "provider": "local",
      "voice": "zh-CN-XiaoxiaoNeural"
    },
    "fraudDetection": {
      "enabled": false,
      "modelPath": "./ai-models/fraud-detection-v1.0.0"
    }
  },
  "storage": {
    "local": {
      "uploadDir": "./uploads",
      "maxFileSize": 10485760,
      "allowedTypes": ["image/jpeg", "image/png", "image/gif", "video/mp4"]
    },
    "cloud": {
      "enabled": false,
      "provider": "aliyun",
      "bucket": "elder-smart-helper-dev",
      "region": "oss-cn-hangzhou"
    }
  },
  "notifications": {
    "email": {
      "enabled": false,
      "smtp": {
        "host": "smtp.gmail.com",
        "port": 587,
        "secure": false,
        "auth": {
          "user": "dev@eldersmarthelper.com",
          "pass": "password"
        }
      },
      "from": "noreply@eldersmarthelper.com"
    },
    "sms": {
      "enabled": false,
      "provider": "twilio",
      "accountSid": "dev_account_sid",
      "authToken": "dev_auth_token",
      "fromNumber": "+15005550006"
    },
    "push": {
      "enabled": false,
      "fcm": {
        "serverKey": "dev_fcm_server_key"
      },
      "apns": {
        "keyId": "dev_key_id",
        "teamId": "dev_team_id",
        "keyFile": "./config/apns-key-dev.p8"
      }
    }
  },
  "monitoring": {
    "enabled": true,
    "sentry": {
      "dsn": "",
      "environment": "development"
    },
    "newRelic": {
      "licenseKey": "",
      "appName": "ElderSmartHelper-Dev"
    },
    "metrics": {
      "enabled": true,
      "port": 9090
    }
  },
  "features": {
    "remoteAssistance": {
      "enabled": true,
      "maxSessionsPerUser": 3,
      "sessionTimeout": 3600
    },
    "voiceAssistant": {
      "enabled": true,
      "wakeWord": "小助",
      "timeout": 10000
    },
    "securityMonitoring": {
      "enabled": true,
      "alertThreshold": {
        "high": 10,
        "medium": 5,
        "low": 1
      }
    },
    "tutorialSystem": {
      "enabled": true,
      "autoRecommend": true,
      "completionReward": true
    }
  },
  "logging": {
    "level": "debug",
    "transports": ["console", "file"],
    "file": {
      "filename": "./logs/app-dev.log",
      "maxsize": 10485760,
      "maxFiles": 10
    },
    "format": "json"
  }
}